# CEF binary distribution URLs and SHA256 checksums.
#
# These must stay in sync with the cef/ submodule commit.
# When bumping CEF:
#   1. Update cef/ submodule to the new commit
#   2. Find matching binary distributions at https://cef-builds.spotifycdn.com/index.html
#   3. Update CEF_ARM64_URL and CEF_X86_64_URL below (same version, different arch suffix)
#   4. Compute SHA256: shasum -a 256 <downloaded-archive>
#   5. Update CEF_ARM64_SHA256 and CEF_X86_64_SHA256 below
#
# Usage in CI (sourced by .github/workflows/release.yml):
#   source cmake/cef-version.env
#   cmake ... -DCRONYMAX_CEF_DIST_URL=$CEF_ARM64_URL
#
# SHA256 values are for documentation and out-of-band verification.
# They are NOT passed to cmake (-DCRONYMAX_CEF_DIST_SHA256) in CI to preserve
# GitHub Actions cache behaviour (cmake would re-download to verify if SHA256 is set).

# CEF 147.0.10+gd58e84d, Chromium 147.0.7727.118
CEF_ARM64_URL=https://cef-builds.spotifycdn.com/cef_binary_147.0.10+gd58e84d+chromium-147.0.7727.118_macosarm64.tar.bz2
CEF_ARM64_SHA256=dcfd3aa0aaccdc5fdc910ae3b087ec69bf019d0c130ae1955a39300c7422e454

CEF_X86_64_URL=https://cef-builds.spotifycdn.com/cef_binary_147.0.10+gd58e84d+chromium-147.0.7727.118_macosx64.tar.bz2
CEF_X86_64_SHA256=5875b7f33264ee24d026ac43e3cd315c66e48638ced2ed682238d6a2b30fe3d4
