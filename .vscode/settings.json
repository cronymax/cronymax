{
  // Use Apple clangd 21.0 — matches the project compiler (/usr/bin/c++)
  // and has better Apple SDK / Objective-C++ knowledge than LLVM-18.
  "clangd.path": "/usr/bin/clangd",
  "clangd.arguments": ["--background-index", "--clang-tidy", "--completion-style=detailed", "--header-insertion=iwyu"],
  // Disable ms-vscode.cpptools IntelliSense engine to eliminate the
  // clangd/cpptools conflict. The cpptools debugger (cppdbg) still works.
  "C_Cpp.intelliSenseEngine": "disabled",
  // Use clangd as the formatter for C/C++ files.
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  // Use Biome as the formatter for TypeScript, TSX, and JSON files.
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "biome.enabled": true,
  "cSpell.words": ["cronymax", "fcntl", "ollama", "oneshot"],
  "chat.tools.terminal.autoApprove": {
    "openspec": true,
    "git submodule": true
  }
}
